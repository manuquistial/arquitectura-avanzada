# Notification service environment (example)
# Copy this file to `.env` and fill credentials.

# Database (delivery log)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/carpeta_ciudadana

# Service Bus (optional, leave empty if not used locally)
SERVICEBUS_CONNECTION_STRING=

# SMTP configuration
SMTP_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_username
SMTP_PASSWORD=your_password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Carpeta Ciudadana

# Webhook (optional)
NOTIF_WEBHOOK_URL=

# OpenTelemetry
OTEL_ENABLED=true
OTEL_SERVICE_NAME=notification-service
OTEL_ENDPOINT=http://localhost:4317

# Environment
ENVIRONMENT=development